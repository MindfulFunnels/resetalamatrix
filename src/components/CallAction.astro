---
import clientData from "../data/config";
const { text } = Astro.props;
---

<button
  class='bg-primary text-white border border-[#801FC6] rounded-xl shadow-lg px-10 text-xl py-6 hover:animate-pop sm:text-lg md:text-xl lg:text-2xl animate-jump'
>
  <a href='#register'>
    {text}
  </a>
</button>

<style>
  @keyframes jump {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  .animate-jump {
    animation: jump 1s infinite;
  }
</style>
